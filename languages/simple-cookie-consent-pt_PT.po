msgstr "Ainda não foram adicionados cookies."

msgid "No cookies yet. Add one manually or run the scanner."
msgstr "Ainda sem cookies. Adicione um manualmente ou execute o scanner."

msgid "Cookie added."
msgstr "Cookie adicionado."

msgid "Cookie updated."
msgstr "Cookie atualizado."

msgid "Cookie deleted."
msgstr "Cookie eliminado."

msgid "Cookie database: %1$d entries loaded from the %2$sOpen Cookie Database%3$s."
msgstr "Base de dados de cookies: %1$d entradas carregadas da %2$sOpen Cookie Database%3$s."

msgid "Run Scanner"
msgstr "Executar Scanner"

msgid "Scan"
msgstr "Analisar"

msgid "Scanning…"
msgstr "A analisar…"

msgid "Scan complete."
msgstr "Análise concluída."

msgid "Scan failed. Please try again."
msgstr "Análise falhou. Por favor tente novamente."

msgid "new cookie(s) found."
msgstr "novo(s) cookie(s) encontrado(s)."

msgid "Manual"
msgstr "Manual"

msgid "e.g. Google Analytics"
msgstr "ex.: Google Analytics"

msgid "e.g. 2 years"
msgstr "ex.: 2 anos"

msgid "— None —"
msgstr "— Nenhuma —"

msgid "all"
msgstr "todos"

msgid "CSS Classes &amp; Custom Properties"
msgstr "Classes CSS e Propriedades Personalizadas"

msgid "Key selectors"
msgstr "Seletores principais"

