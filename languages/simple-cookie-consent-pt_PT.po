#. Plugin Name of the plugin
msgid "Simple Cookie Consent"
msgstr "Simple Cookie Consent"

#. Plugin URI of the plugin
msgid "https://github.com/sergiorsmaster/simple-wp-cookie-consent"
msgstr "https://github.com/sergiorsmaster/simple-wp-cookie-consent"

#. Description of the plugin
msgid "A simple, free, and open-source cookie consent banner. No hidden Pro features, no subscription."
msgstr "Um banner de consentimento de cookies simples, gratuito e de código aberto. Sem versão Pro, sem mensalidades."

#. Author of the plugin
msgid "Sergio Ricardo"
msgstr "Sergio Ricardo"

msgid "We use cookies"
msgstr "Utilizamos cookies"

msgid "We use cookies to improve your experience on our website. Please choose your cookie preferences below."
msgstr "Utilizamos cookies para melhorar a sua experiência no nosso website. Por favor escolha as suas preferências abaixo."

msgid "Accept All"
msgstr "Aceitar Todos"

msgid "Deny All"
msgstr "Recusar Todos"

msgid "Preferences"
msgstr "Preferências"

msgid "Cookie Preferences"
msgstr "Preferências de Cookies"

msgid "Choose which cookies you allow. You can change your preferences at any time."
msgstr "Escolha quais cookies permite. Pode alterar as suas preferências em qualquer momento."

msgid "Save Preferences"
msgstr "Guardar Preferências"

msgid "Always active"
msgstr "Sempre ativo"

msgid "Necessary"
msgstr "Necessários"

msgid "Required for the website to function properly. These cookies cannot be disabled."
msgstr "Necessários para o funcionamento correto do website. Estes cookies não podem ser desativados."

msgid "Analytics"
msgstr "Análise"

msgid "Help us understand how visitors interact with the website by collecting anonymous data."
msgstr "Ajudam-nos a compreender como os visitantes interagem com o website através da recolha de dados anónimos."

msgid "Marketing"
msgstr "Marketing"

msgid "Used to track visitors across websites to display relevant and personalized advertisements."
msgstr "Utilizados para seguir visitantes entre websites e apresentar publicidade relevante e personalizada."

msgid "Functional"
msgstr "Funcionais"

msgid "Allow the website to remember your preferences such as language or region."
msgstr "Permitem que o website recorde as suas preferências, como idioma ou região."

msgid "Privacy Policy"
msgstr "Política de Privacidade"

msgid "Cookie Policy"
msgstr "Política de Cookies"

msgid "Imprint"
msgstr "Aviso Legal"

msgid "Close"
msgstr "Fechar"

msgid "Cookie Settings"
msgstr "Definições de Cookies"

msgid "Do Not Sell My Personal Information"
msgstr "Não Vender as Minhas Informações Pessoais"

msgid "Cookie Consent Settings"
msgstr "Definições de Consentimento de Cookies"

msgid "Cookie Consent"
msgstr "Consentimento de Cookies"

msgid "Enable Cookie Banner"
msgstr "Ativar Banner de Cookies"

msgid "Show the cookie consent banner on the frontend."
msgstr "Mostrar o banner de consentimento de cookies no frontend."

msgid "Banner Title"
msgstr "Título do Banner"

msgid "Banner Text"
msgstr "Texto do Banner"

msgid "Accept Button Label"
msgstr "Etiqueta do Botão Aceitar"

msgid "Deny Button Label"
msgstr "Etiqueta do Botão Recusar"

msgid "Preferences Button Label"
msgstr "Etiqueta do Botão Preferências"

msgid "Preferences Dialog"
msgstr "Diálogo de Preferências"

msgid "Dialog Title"
msgstr "Título do Diálogo"

msgid "Dialog Description"
msgstr "Descrição do Diálogo"

msgid "Save Button Label"
msgstr "Etiqueta do Botão Guardar"

msgid "Privacy Policy Page"
msgstr "Página de Política de Privacidade"

msgid "Cookie Policy Page"
msgstr "Página de Política de Cookies"

msgid "Imprint Page"
msgstr "Página de Aviso Legal"

msgid "Floating Preferences Icon"
msgstr "Ícone Flutuante de Preferências"

msgid "Show a small cookie icon on the page after consent is saved, so visitors can change their preferences at any time. You can also use the [scc_preferences] shortcode instead."
msgstr "Mostrar um pequeno ícone de cookie na página após o consentimento ser guardado, para que os visitantes possam alterar as suas preferências em qualquer momento. Também pode utilizar o shortcode [scc_preferences]."

msgid "Banner Position"
msgstr "Posição do Banner"

msgid "Bottom Bar (full width)"
msgstr "Barra Inferior (largura total)"

msgid "Top Bar (full width)"
msgstr "Barra Superior (largura total)"

msgid "Bottom Left (corner box)"
msgstr "Inferior Esquerdo (caixa de canto)"

msgid "Bottom Right (corner box)"
msgstr "Inferior Direito (caixa de canto)"

msgid "Center Modal"
msgstr "Modal Central"

msgid "Background Color"
msgstr "Cor de Fundo"

msgid "Text Color"
msgstr "Cor do Texto"

msgid "Accent Color"
msgstr "Cor de Destaque"

msgid "Used for the Accept button and toggle switch."
msgstr "Utilizada para o botão Aceitar e o interruptor de alternância."

msgid "Applies to banner, modal, and buttons."
msgstr "Aplica-se ao banner, modal e botões."

msgid "Border & Shape"
msgstr "Borda e Forma"

msgid "Corner Radius (px)"
msgstr "Raio dos Cantos (px)"

msgid "Border Width (px)"
msgstr "Largura da Borda (px)"

msgid "Border Color"
msgstr "Cor da Borda"

msgid "Banner Width (px)"
msgstr "Largura do Banner (px)"

msgid "Applies to corner and center modal positions (px). Set to 0 or leave empty to use the default width."
msgstr "Aplica-se às posições de canto e modal central (px). Defina como 0 ou deixe em branco para usar a largura padrão."

msgid "Buttons"
msgstr "Botões"

msgid "Secondary Button Style"
msgstr "Estilo do Botão Secundário"

msgid "Outline"
msgstr "Contorno"

msgid "Ghost"
msgstr "Fantasma"

msgid "Deny and Preferences buttons appear as outlined buttons alongside Accept."
msgstr "Os botões Recusar e Preferências aparecem como botões com contorno ao lado do Aceitar."

msgid "Deny and Preferences appear as text links with underline, keeping the Accept button as the only visual button."
msgstr "Recusar e Preferências aparecem como links de texto com sublinhado, mantendo o botão Aceitar como único botão visual."

msgid "The Accept button is always filled with the Accent color."
msgstr "O botão Aceitar é sempre preenchido com a cor de destaque."

msgid "Logo"
msgstr "Logótipo"

msgid "Logo Source"
msgstr "Fonte do Logótipo"

msgid "No logo"
msgstr "Sem logótipo"

msgid "Use site logo (set in Customizer)"
msgstr "Usar logótipo do site (definido no Customizer)"

msgid "Custom upload"
msgstr "Upload personalizado"

msgid "Upload Logo"
msgstr "Carregar Logótipo"

msgid "Select Image"
msgstr "Selecionar Imagem"

msgid "Remove"
msgstr "Remover"

msgid "Custom CSS"
msgstr "CSS Personalizado"

msgid "Add custom CSS to override the default banner styles."
msgstr "Adicione CSS personalizado para substituir os estilos padrão do banner."

msgid "Preview Banner"
msgstr "Pré-visualizar Banner"

msgid "Preview"
msgstr "Pré-visualização"

msgid "Open Preview"
msgstr "Abrir Pré-visualização"

msgid "Opens your site homepage in a new tab and forces the cookie banner to appear, even if you have already given consent. This preview is only visible to logged-in administrators — regular visitors are never affected by this URL parameter."
msgstr "Abre a página inicial do seu site num novo separador e força a aparição do banner de cookies, mesmo que já tenha dado consentimento. Esta pré-visualização é apenas visível para administradores com sessão iniciada — os visitantes regulares nunca são afetados por este parâmetro."

msgid "GDPR — European Union"
msgstr "RGPD — União Europeia"

msgid "LGPD — Brazil"
msgstr "LGPD — Brasil"

msgid "CCPA — United States (California)"
msgstr "CCPA — Estados Unidos (Califórnia)"

msgid "Non-essential cookies are blocked until the visitor explicitly accepts them. Required for websites targeting users in the EU/EEA."
msgstr "Os cookies não essenciais são bloqueados até o visitante os aceitar explicitamente. Obrigatório para websites direcionados a utilizadores na UE/EEE."

msgid "Same opt-in model as GDPR. Required for websites targeting users in Brazil."
msgstr "Mesmo modelo de opt-in que o RGPD. Obrigatório para websites direcionados a utilizadores no Brasil."

msgid "Cookies are allowed by default. Visitors can opt out of the sale of their personal data. Required for businesses targeting California residents above certain thresholds."
msgstr "Os cookies são permitidos por defeito. Os visitantes podem optar por não vender os seus dados pessoais. Obrigatório para empresas que visam residentes na Califórnia acima de determinados limites."

msgid "Applicable Law"
msgstr "Lei Aplicável"

msgid "Select the privacy law that applies to your website. This controls whether the banner uses an opt-in or opt-out model."
msgstr "Selecione a lei de privacidade que se aplica ao seu website. Isto controla se o banner utiliza um modelo de opt-in ou opt-out."

msgid "Opt-in"
msgstr "Opt-in"

msgid "Opt-out"
msgstr "Opt-out"

msgid "Cookies blocked until consent is granted"
msgstr "Cookies bloqueados até o consentimento ser concedido"

msgid "Cookies are NOT blocked before interaction"
msgstr "Cookies NÃO são bloqueados antes da interação"

msgid "Banner shown on first visit"
msgstr "Banner mostrado na primeira visita"

msgid "Banner shown as an informational notice"
msgstr "Banner mostrado como aviso informativo"

msgid "Preferences button hidden"
msgstr "Botão de preferências ocultado"

msgid "Accept All / Deny All / Preferences buttons shown"
msgstr "Botões Aceitar Todos / Recusar Todos / Preferências mostrados"

msgid "\"Do Not Sell My Personal Information\" opt-out shown"
msgstr "Opt-out \"Não Vender as Minhas Informações Pessoais\" mostrado"

msgid "\"Do Not Sell\" Button Label"
msgstr "Etiqueta do Botão \"Não Vender\""

msgid "Label for the opt-out button shown in the banner when CCPA mode is active."
msgstr "Etiqueta para o botão de opt-out mostrado no banner quando o modo CCPA está ativo."

msgid "Enable GTM Consent Mode v2"
msgstr "Ativar GTM Consent Mode v2"

msgid "Injects gtag consent defaults before GTM loads and updates signals when the visitor makes a choice."
msgstr "Injeta os padrões de consentimento gtag antes do GTM carregar e atualiza os sinais quando o visitante faz uma escolha."

msgid "Consent Mode"
msgstr "Modo de Consentimento"

msgid "Basic"
msgstr "Básico"

msgid "Advanced"
msgstr "Avançado"

msgid "Recommended"
msgstr "Recomendado"

msgid "Google tags fire in a limited cookieless mode before consent. Enables statistical modelling for non-consenting users. Requires GTM to be configured accordingly."
msgstr "As tags do Google disparam em modo limitado sem cookies antes do consentimento. Permite modelação estatística para utilizadores que não consentiram. Requer configuração adequada do GTM."

msgid "Google tags do not fire before the visitor consents. Strictest compliance, but no data modelling for non-consenting users."
msgstr "As tags do Google não disparam antes do visitante consentir. Conformidade mais estrita, mas sem modelação de dados para utilizadores que não consentiram."

msgid "GTM Signals"
msgstr "Sinais GTM"

msgid "Signal Mapping"
msgstr "Mapeamento de Sinais"

msgid "Wait for Update (ms)"
msgstr "Aguardar Atualização (ms)"

msgid "How long (in milliseconds) GTM waits for a consent update before firing tags. Default: 500."
msgstr "Quanto tempo (em milissegundos) o GTM aguarda por uma atualização de consentimento antes de disparar as tags. Padrão: 500."

msgid "Google Tag Manager"
msgstr "Google Tag Manager"

msgid "Debug Mode"
msgstr "Modo de Depuração"

msgid "Log all consent actions to the browser console prefixed with [SCC]. Disable on production."
msgstr "Registar todas as ações de consentimento na consola do navegador com o prefixo [SCC]. Desativar em produção."

msgid "Debug"
msgstr "Depuração"

msgid "Compatibility"
msgstr "Compatibilidade"

msgid "WP Consent Level API"
msgstr "WP Consent Level API"

msgid "The %1$sWP Consent Level API%2$s is a standard interface that lets plugins like Site Kit read consent without knowing anything about this plugin."
msgstr "A %1$sWP Consent Level API%2$s é uma interface padrão que permite que plugins como o Site Kit leiam o consentimento sem saber nada sobre este plugin."

msgid "WP Consent Level API is active. Consent is synced automatically on every page load."
msgstr "A WP Consent Level API está ativa. O consentimento é sincronizado automaticamente em cada carregamento de página."

msgid "WP Consent Level API is not active. %1$sInstall the plugin%2$s to allow third-party plugins to read consent without extra configuration."
msgstr "A WP Consent Level API não está ativa. %1$sInstale o plugin%2$s para permitir que plugins de terceiros leiam o consentimento sem configuração adicional."

msgid "Polylang"
msgstr "Polylang"

msgid "Polylang is active. Banner strings are registered for translation under Languages → String Translations."
msgstr "O Polylang está ativo. As strings do banner estão registadas para tradução em Idiomas → Traduções de Strings."

msgid "Polylang is not active. When installed, banner title, text, and button labels will be translatable per language."
msgstr "O Polylang não está ativo. Quando instalado, o título, texto e etiquetas de botões do banner serão traduzíveis por idioma."

msgid "Site Kit by Google"
msgstr "Site Kit by Google"

msgid "Site Kit is active. Consent is passed automatically via GTM Consent Mode v2 signals and the WP Consent API."
msgstr "O Site Kit está ativo. O consentimento é transmitido automaticamente através dos sinais GTM Consent Mode v2 e da WP Consent API."

msgid "Site Kit is not active. When installed, it will automatically respect GTM Consent Mode v2 signals set by this plugin."
msgstr "O Site Kit não está ativo. Quando instalado, respeitará automaticamente os sinais GTM Consent Mode v2 definidos por este plugin."

msgid "Consent stored for 1 year"
msgstr "Consentimento armazenado por 1 ano"

