msgstr "Cookie-Einwilligungseinstellungen"

msgid "Cookie Consent"
msgstr "Cookie-Einwilligung"

msgid "Enable Cookie Banner"
msgstr "Cookie-Banner aktivieren"

msgid "Show the cookie consent banner on the frontend."
msgstr "Das Cookie-Einwilligungs-Banner im Frontend anzeigen."

msgid "Banner Title"
msgstr "Banner-Titel"

msgid "Banner Text"
msgstr "Banner-Text"

