#. Plugin Name of the plugin
msgid "Consentric"
msgstr "Consentric"

#. Plugin URI of the plugin
msgid "https://github.com/sergiorsmaster/consentric"
msgstr "https://github.com/sergiorsmaster/consentric"

#. Description of the plugin
msgid "A simple, free, and open-source cookie consent banner. No hidden Pro features, no subscription."
msgstr "Ein einfaches, kostenloses und quelloffenes Cookie-Einwilligungs-Banner. Keine versteckten Pro-Funktionen, keine Abo-Modelle."

#. Author of the plugin
msgid "Sergio Ricardo"
msgstr "Sergio Ricardo" 

#. Admin tab labels
msgid "General"
msgstr "Allgemein"

msgid "Appearance"
msgstr "Darstellung"

msgid "Jurisdiction"
msgstr "Rechtsgebiet"

msgid "Integrations"
msgstr "Integrationen"

msgid "Cookies"
msgstr "Cookies"

msgid "Help"
msgstr "Hilfe"

msgid "We use cookies"
msgstr "Wir verwenden Cookies"

msgid "We use cookies to improve your experience on our website. Please choose your cookie preferences below."
msgstr "Wir verwenden Cookies, um Ihre Erfahrung auf unserer Website zu verbessern. Bitte wählen Sie Ihre Cookie-Einstellungen unten."

msgid "Accept All"
msgstr "Alle akzeptieren"

msgid "Deny All"
msgstr "Alle ablehnen"

msgid "Preferences"
msgstr "Einstellungen"

msgid "Cookie Preferences"
msgstr "Cookie-Einstellungen"

msgid "Choose which cookies you allow. You can change your preferences at any time."
msgstr "Wählen Sie, welche Cookies Sie erlauben. Sie können Ihre Einstellungen jederzeit ändern."

msgid "Save Preferences"
msgstr "Einstellungen speichern"

msgid "Always active"
msgstr "Immer aktiv"

msgid "Necessary"
msgstr "Notwendig"

msgid "Required for the website to function properly. These cookies cannot be disabled."
msgstr "Für die ordnungsgemäße Funktion der Website erforderlich. Diese Cookies können nicht deaktiviert werden."

msgid "Analytics"
msgstr "Analyse"

msgid "Help us understand how visitors interact with the website by collecting anonymous data."
msgstr "Helfen uns zu verstehen, wie Besucher mit der Website interagieren, indem sie anonyme Daten sammeln."

msgid "Marketing"
msgstr "Marketing"

msgid "Used to track visitors across websites to display relevant and personalized advertisements."
msgstr "Werden verwendet, um Besucher websiteübergreifend zu verfolgen und relevante, personalisierte Werbung anzuzeigen."

msgid "Functional"
msgstr "Funktional"

msgid "Allow the website to remember your preferences such as language or region."
msgstr "Ermöglichen der Website, Ihre Einstellungen wie Sprache oder Region zu speichern."

