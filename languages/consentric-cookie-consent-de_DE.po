msgstr "Beschriftung der Schaltfläche „Akzeptieren”"

msgid "Deny Button Label"
msgstr "Beschriftung der Schaltfläche „Ablehnen”"

msgid "Preferences Button Label"
msgstr "Beschriftung der Schaltfläche „Einstellungen”"

