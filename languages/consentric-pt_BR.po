msgstr "Cor de Destaque"

msgid "Used for the Accept button and toggle switch."
msgstr "Usada para o botão Aceitar e o interruptor."

msgid "Applies to banner, modal, and buttons."
msgstr "Aplica-se ao banner, modal e botões."

msgid "Border & Shape"
msgstr "Borda e Forma"

