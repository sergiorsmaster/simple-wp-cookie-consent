#. Plugin Name of the plugin
msgid "Consentric"
msgstr "Consentric"

#. Plugin URI of the plugin
msgid "https://github.com/sergiorsmaster/consentric"
msgstr "https://github.com/sergiorsmaster/consentric"

#. Description of the plugin
msgid "A simple, free, and open-source cookie consent banner. No hidden Pro features, no subscription."
msgstr "Um banner de consentimento de cookies simples, gratuito e de código aberto. Sem versão Pro, sem assinatura."

#. Author of the plugin
msgid "Sergio Ricardo"
msgstr "Sergio Ricardo"

#. Admin tab labels
msgid "General"
msgstr "Geral"

msgid "Appearance"
msgstr "Aparência"

msgid "Jurisdiction"
msgstr "Jurisdição"

msgid "Integrations"
msgstr "Integrações"

msgid "Cookies"
msgstr "Cookies"

msgid "Help"
msgstr "Ajuda"

msgid "We use cookies"
msgstr "Usamos cookies"

msgid "We use cookies to improve your experience on our website. Please choose your cookie preferences below."
msgstr "Usamos cookies para melhorar sua experiência no nosso site. Por favor, escolha suas preferências abaixo."

msgid "Accept All"
msgstr "Aceitar Todos"

msgid "Deny All"
msgstr "Recusar Todos"

msgid "Preferences"
msgstr "Preferências"

msgid "Cookie Preferences"
msgstr "Preferências de Cookies"

msgid "Choose which cookies you allow. You can change your preferences at any time."
msgstr "Escolha quais cookies você permite. Você pode alterar suas preferências a qualquer momento."

msgid "Save Preferences"
msgstr "Salvar Preferências"

msgid "Always active"
msgstr "Sempre ativo"

msgid "Necessary"
msgstr "Necessários"

msgid "Required for the website to function properly. These cookies cannot be disabled."
msgstr "Necessários para o funcionamento correto do site. Esses cookies não podem ser desativados."

msgid "Analytics"
msgstr "Análise"

msgid "Help us understand how visitors interact with the website by collecting anonymous data."
msgstr "Nos ajudam a entender como os visitantes interagem com o site por meio da coleta de dados anônimos."

msgid "Marketing"
msgstr "Marketing"

msgid "Used to track visitors across websites to display relevant and personalized advertisements."
msgstr "Usados para rastrear visitantes entre sites e exibir publicidade relevante e personalizada."

msgid "Functional"
msgstr "Funcionais"

msgid "Allow the website to remember your preferences such as language or region."
msgstr "Permitem que o site lembre suas preferências, como idioma ou região."

