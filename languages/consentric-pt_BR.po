msgstr "API JavaScript"

msgid "All methods are available on the global"
msgstr "Todos os métodos estão disponíveis no objeto global"

msgid "object."
msgstr "objeto."

msgid "Method / Event"
msgstr "Método / Evento"

msgid "Grant consent for all cookie categories and hide the banner."
msgstr "Conceder consentimento para todas as categorias de cookies e ocultar o banner."

msgid "Deny consent for all non-necessary categories and hide the banner."
msgstr "Recusar consentimento para todas as categorias não essenciais e ocultar o banner."

msgid "Save a partial consent object. Example:"
msgstr "Salvar um objeto de consentimento parcial. Exemplo:"

msgid "Programmatically open the preferences modal."
msgstr "Abrir o modal de preferências programaticamente."

msgid "Programmatically show the consent banner (e.g. from a \"Review cookie settings\" link)."
msgstr "Exibir o banner de consentimento programaticamente (ex.: a partir de um link \"Revisar configurações de cookies\")."

msgid "Returns true if consent has been granted for the given category (e.g. \"analytics\")."
msgstr "Retorna verdadeiro se o consentimento foi concedido para a categoria informada (ex.: \"analytics\")."

msgid "Returns true if the visitor has already made a consent choice (banner was actioned)."
msgstr "Retorna verdadeiro se o visitante já fez uma escolha de consentimento (o banner foi acionado)."

msgid "Fired on document after any consent save. Listen with:"
msgstr "Disparado no documento após qualquer salvamento de consentimento. Ouça com:"

msgid "(CustomEvent on document)"
msgstr "(CustomEvent no documento)"

